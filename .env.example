# Database (Turso for production, SQLite for local dev)
DATABASE_URL="file:./prisma/dev.db"
TURSO_DATABASE_URL="libsql://your-db-name-your-org.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Google OAuth (Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-random-secret"

# PayPal (optional - admin bypasses subscription)
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-paypal-client-id"
NEXT_PUBLIC_PAYPAL_PLAN_ID="your-paypal-plan-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"

# AI API Keys (can also be set via admin panel)
ANTHROPIC_API_KEY="your-anthropic-api-key"
OPENAI_API_KEY="your-openai-api-key"
GOOGLE_AI_API_KEY="your-google-ai-api-key"
